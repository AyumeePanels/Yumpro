<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.UproByYum" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_green</item>
        <item name="colorPrimaryVariant">@color/neon_green_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/neon_green</item>
        <item name="colorSecondaryVariant">@color/neon_green_dark</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/status_down</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="materialButtonStyle">@style/Widget.UproByYum.Button</item>
    </style>

    <style name="Theme.UproByYum.Splash" parent="Theme.UproByYum">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Widget.UproByYum.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/neon_green</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="CardStyle" parent="">
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:layout_marginVertical">6dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TextAppearance.UproByYum.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.UproByYum.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.UproByYum.Status">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

</resources>
